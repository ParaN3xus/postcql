[openai]
api_key = "replace-me"
base_url = "https://api.openai.com/v1"
model = "gpt-5.4"
api_mode = "chat_completions"

[app]
work_dir = "work"
codeql_sarif_filename = "all.sarif"

[binaries]
mcp_server = "mcp-language-server"
clangd = "clangd"
typst = "typst"
mcp_server_path_entries = []

[agent]
max_turns = 64
max_concurrency = 4
